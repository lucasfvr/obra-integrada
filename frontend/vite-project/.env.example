# Porta onde o backend roda localmente
PORT=5000

# Host local da aplicação
HOST=localhost

# URL do banco Neon PostgreSQL
# Pegue em: Neon Dashboard > Connection Details
DATABASE_URL=postgresql://user:password@host/database

# Chave usada para gerar/verificar JWT
JWT_SECRET=your_jwt_secret_here

# Ambiente da aplicação
NODE_ENV=development