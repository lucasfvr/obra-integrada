generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model obras {
  id                       Int       @id @default(autoincrement())
  nome_obra                String
  localizacao              String?
  status                   String    @default("Planejada")
  valor_orcado             Decimal?  @db.Decimal(14, 2)
  usuario_ultima_alteracao Int?
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  updated_at               DateTime? @default(now()) @db.Timestamp(6)

  users users? @relation(fields: [usuario_ultima_alteracao], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pessoa_fisica {
  id      Int    @id @default(autoincrement())
  user_id Int?   @unique
  nome    String
  cpf     String @unique

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model pessoa_juridica {
  id           Int      @id @default(autoincrement())
  user_id      Int?     @unique
  razao_social String
  cnpj         String   @unique
  is_brief     Boolean? @default(false)

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id              Int              @id @default(autoincrement())
  username        String?          @unique
  email           String           @unique
  password        String?
  tipo            String
  created_at      DateTime?        @default(now()) @db.Timestamp(6)

  obras           obras[]
  pessoa_fisica   pessoa_fisica?
  pessoa_juridica pessoa_juridica?
}