DATABASE_URL=postgresql://user:password@localhost:5432/obra_integrada
JWT_SECRET=gere-com-openssl-rand-hex-32-minimo-32-caracteres
PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# --- STORAGE (local para dev, S3/R2 para produção) ---
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=obra-integrada-uploads
# STORAGE_REGION=sa-east-1
# STORAGE_ACCESS_KEY=sua-access-key-aws
# STORAGE_SECRET_KEY=sua-secret-key-aws
# STORAGE_PUBLIC_URL_BASE=https://seu-bucket.s3.sa-east-1.amazonaws.com

# --- CRIPTOGRAFIA DE DADOS SENSÍVEIS (CPF, CNPJ) ---
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=gere-64-chars-hex-aleatorios-aqui

# --- FRONTEND ---
FRONTEND_URL=http://localhost:5173

# --- OBSERVABILIDADE (opcional) ---
# SENTRY_DSN=https://xxxx@sentry.io/yyyy

# --- VARIÁVEIS AUTOMÁTICAS (Vercel define automaticamente) ---
# VERCEL=1
# HOST=localhost
