# Copie este arquivo para `.env` e preencha os valores.
# O `.env` real NÃO é versionado (.gitignore).

PORT=5000
NODE_ENV=development

# Lista separada por vírgula. Origens sem "Origin" são BLOQUEADAS.
CORS_ORIGINS=http://localhost:5173

# Conexão do banco (Postgres ou NeonDB).
DATABASE_URL=postgresql://user:password@localhost:5432/obra_integrada

# 512 bits hex. Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Local em dev, s3 em prod.
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=obra-integrada-uploads
# STORAGE_REGION=sa-east-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL_BASE=https://seu-bucket.s3.sa-east-1.amazonaws.com

# 64 chars hex. Usado para criptografar CPF/CNPJ.
# ENCRYPTION_KEY=

# URL canônica do frontend (usada em e-mails e redirects).
FRONTEND_URL=http://localhost:5173

# Opcional: monitoramento de erros.
# SENTRY_DSN=