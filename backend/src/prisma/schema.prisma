generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model tb_etapa {
  id_etapa          Int                 @id @default(autoincrement())
  id_obra           Int?
  nome              String?
  previsao_inicio   DateTime?           @db.Date
  previsao_fim      DateTime?           @db.Date
  id_status         Int?
  tb_status         tb_status?          @relation(fields: [id_status], references: [id_status], onDelete: NoAction, onUpdate: NoAction, map: "fk_etapa_status")
  tb_obra           tb_obra?            @relation(fields: [id_obra], references: [id_obra], onDelete: NoAction, onUpdate: NoAction)
  tb_etapa_material tb_etapa_material[]

  @@index([id_obra], map: "idx_etapa_obra")
}

model tb_etapa_material {
  id_etapa    Int
  id_material Int
  quantidade  Decimal?    @db.Decimal(10, 2)
  tb_etapa    tb_etapa    @relation(fields: [id_etapa], references: [id_etapa], onDelete: Cascade, onUpdate: NoAction)
  tb_material tb_material @relation(fields: [id_material], references: [id_material], onDelete: NoAction, onUpdate: NoAction)

  @@id([id_etapa, id_material])
}

model tb_fabricante {
  id_fabricante          Int                      @id @default(autoincrement())
  nome_fabricante        String
  tb_material_fabricante tb_material_fabricante[]
}

model tb_material {
  id_material             Int                       @id @default(autoincrement())
  nome                    String
  unidade_medida          String?
  preco_unitario          Decimal?                  @db.Decimal(10, 2)
  criado_em               DateTime?                 @default(now()) @db.Timestamp(6)
  densidade               Decimal?                  @db.Decimal(10, 3)
  resistencia             Decimal?                  @db.Decimal(10, 2)
  volume_unitario         Decimal?                  @db.Decimal(10, 3)
  peso_unitario           Decimal?                  @db.Decimal(10, 3)
  quantidade_atual        Decimal?                  @db.Decimal(10, 3)
  observacoes             String?
  tb_etapa_material       tb_etapa_material[]
  tb_material_fabricante  tb_material_fabricante[]
  tb_material_requisitado tb_material_requisitado[]
}

model tb_material_fabricante {
  id_material   Int
  id_fabricante Int
  tb_fabricante tb_fabricante @relation(fields: [id_fabricante], references: [id_fabricante], onDelete: NoAction, onUpdate: NoAction)
  tb_material   tb_material   @relation(fields: [id_material], references: [id_material], onDelete: NoAction, onUpdate: NoAction)

  @@id([id_material, id_fabricante])
}

model tb_material_requisitado {
  id_requisicao Int
  id_material   Int
  quantidade    Decimal?      @db.Decimal(10, 2)
  tb_material   tb_material   @relation(fields: [id_material], references: [id_material], onDelete: NoAction, onUpdate: NoAction)
  tb_requisicao tb_requisicao @relation(fields: [id_requisicao], references: [id_requisicao], onDelete: NoAction, onUpdate: NoAction)

  @@id([id_requisicao, id_material])
}

model tb_obra {
  id_obra                 Int                  @id @default(autoincrement())
  nome                    String
  tipo_obra               String?
  logradouro              String?
  numero                  String?
  bairro                  String?
  cidade                  String?
  estado                  String?              @db.Char(2)
  cep                     String?
  latitude                Decimal?             @db.Decimal(10, 7)
  longitude               Decimal?             @db.Decimal(10, 7)
  data_inicio             DateTime?            @db.Date
  previsao_termino        DateTime?            @db.Date
  data_termino_real       DateTime?            @db.Date
  valor_orcado            Decimal?             @db.Decimal(12, 2)
  custo_atual             Decimal?             @db.Decimal(12, 2)
  observacoes             String?
  id_usuario_responsavel  Int?
  id_status               Int?
  contato_emergencia_nome String?
  contato_emergencia_fone String?
  /// Dados Técnicos
  area_terreno            Float?
  area_construida         Float?
  objetivo                String?
  nome_proprietario_obra  String?
  /// Legalização
  numero_alvara           String?
  art_rrt                 String?
  /// Breakdown de Orçamento
  orcamento_material      Decimal?             @db.Decimal(12, 2)
  orcamento_mao_obra      Decimal?             @db.Decimal(12, 2)
  orcamento_taxas         Decimal?             @db.Decimal(12, 2)
  tb_diario_obra          tb_diario_obra[]
  tb_documento            tb_documento[]
  tb_estoque_obra         tb_estoque_obra[]
  tb_etapa                tb_etapa[]
  tb_financeiro_obra      tb_financeiro_obra[]
  tb_status               tb_status?           @relation(fields: [id_status], references: [id_status], onDelete: NoAction, onUpdate: NoAction, map: "fk_obra_status")
  tb_usuario              tb_usuario?          @relation(fields: [id_usuario_responsavel], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_obra_usuario")
  tb_obra_cliente         tb_obra_cliente[]
  tb_requisicao           tb_requisicao[]
  tb_rh_ponto_diaria      tb_rh_ponto_diaria[]
  tb_tarefa               tb_tarefa[]
  tb_usuario_obra         tb_usuario_obra[]
  tb_vaga                 tb_vaga[]

  @@index([id_usuario_responsavel], map: "idx_obra_usuario")
}

/// Estoque inicial de materiais por obra (separado do catálogo global tb_material)
model tb_estoque_obra {
  id_estoque      Int                       @id @default(autoincrement())
  id_obra         Int
  nome_material   String
  unidade_medida  String                    @default("Unidade")
  quantidade      Decimal                   @default(0) @db.Decimal(10, 3)
  criado_em       DateTime                  @default(now()) @db.Timestamp(6)
  tb_obra         tb_obra                   @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade, onUpdate: NoAction)
  tb_movimentacao tb_movimentacao_estoque[]

  @@index([id_obra], map: "idx_estoque_obra")
}

model tb_papel {
  id_papel        Int               @id @default(autoincrement())
  nome            String
  tb_usuario_obra tb_usuario_obra[]
}

model tb_requisicao {
  id_requisicao           Int                       @id @default(autoincrement())
  id_obra                 Int?
  quantidade_planejada    Decimal?                  @db.Decimal(10, 2)
  quantidade_usada        Decimal?                  @db.Decimal(10, 2)
  data_registro           DateTime?                 @default(now()) @db.Timestamp(6)
  id_usuario              Int?
  tb_material_requisitado tb_material_requisitado[]
  tb_usuario              tb_usuario?               @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_req_usuario")
  tb_obra                 tb_obra?                  @relation(fields: [id_obra], references: [id_obra], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_obra], map: "idx_req_obra")
}

model tb_status {
  id_status Int        @id @default(autoincrement())
  nome      String
  tb_etapa  tb_etapa[]
  tb_obra   tb_obra[]
}

model tb_usuario {
  id_usuario                   Int                       @id @default(autoincrement())
  nome                         String
  funcao                       String?
  telefone                     String?
  email                        String?                   @unique
  username                     String?                   @unique
  senha                        String?
  tipo_registro_profissional   String?
  numero_registro_profissional String?
  tipo_usuario                 String?
  role                         String?                   @default("USER")
  id_cliente                   Int?
  /// PENDENTE | VERIFICADO | INVALIDO
  status_profissional          String?                   @default("PENDENTE")
  certificacoes                Json?
  experiencias                 String?
  endereco                     String?
  cargo_base                   String?
  cnpj                         String?                   @unique
  cnpj_empreiteira             String?
  cpf                          String?                   @unique
  data_admissao                DateTime?                 @db.Date
  inscricao_estadual           String?
  is_terceirizado              Boolean                   @default(false)
  lgpd_consentimento           Boolean                   @default(false)
  matricula                    String?                   @unique
  porte_empresa                String?
  razao_social                 String?
  razao_social_empreiteira     String?
  status                       String                    @default("ATIVO")
  tipo_vinculo                 String?
  uso_plataforma               String?
  acesso_rh                    Boolean                   @default(false)
  tb_certificacao              tb_certificacao[]
  tb_diario_obra               tb_diario_obra[]
  tb_financeiro_obra           tb_financeiro_obra[]
  tb_log_auditoria             tb_log_auditoria[]
  tb_movimentacao_estoque      tb_movimentacao_estoque[]
  tb_obra                      tb_obra[]
  tb_requisicao                tb_requisicao[]
  tb_rh_conta_banco            tb_rh_conta_banco[]
  tb_rh_ponto_diaria           tb_rh_ponto_diaria[]
  tb_rh_residencial            tb_rh_residencial[]
  tb_rh_salario                tb_rh_salario[]
  tb_tarefa_usuario            tb_tarefa_usuario[]
  tb_cliente                   tb_cliente?               @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_cliente")
  tb_usuario_obra              tb_usuario_obra[]
}

model tb_usuario_obra {
  id_usuario Int
  id_obra    Int
  id_papel   Int?
  valor_dia  Decimal?   @default(0) @db.Decimal(10, 2)
  tb_papel   tb_papel?  @relation(fields: [id_papel], references: [id_papel], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_obra_papel")
  tb_obra    tb_obra    @relation(fields: [id_obra], references: [id_obra], onDelete: NoAction, onUpdate: NoAction)
  tb_usuario tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@id([id_usuario, id_obra])
}

model tb_cliente {
  id_cliente         Int                  @id @default(autoincrement())
  nome_razao         String
  cpf_cnpj           String               @unique
  telefone           String?
  email              String?
  criado_em          DateTime?            @default(now()) @db.Timestamp(6)
  /// ATIVO | INATIVO | TRIAL | SUSPENSO
  status_assinatura  String?              @default("ATIVO")
  validade_plano     DateTime?            @db.Date
  tb_candidato       tb_candidato[]
  tb_entrevista      tb_entrevista[]
  tb_obra_cliente    tb_obra_cliente[]
  tb_rh_conta_banco  tb_rh_conta_banco[]
  tb_rh_ponto_diaria tb_rh_ponto_diaria[]
  tb_rh_residencial  tb_rh_residencial[]
  tb_rh_salario      tb_rh_salario[]
  tb_talento         tb_talento[]
  tb_usuario         tb_usuario[]
  tb_vaga            tb_vaga[]
}

model tb_obra_cliente {
  id_obra    Int
  id_cliente Int
  tb_cliente tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)
  tb_obra    tb_obra    @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_obra, id_cliente])
}

model tb_documento {
  id_documento Int       @id @default(autoincrement())
  id_obra      Int
  nome         String
  tipo         String?
  url          String
  data_upload  DateTime? @default(now()) @db.Timestamp(6)
  tb_obra      tb_obra   @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade, onUpdate: NoAction)
}

/// Diário da obra — registros diários com foto e descricão
model tb_diario_obra {
  id_diario         Int        @id @default(autoincrement())
  id_obra           Int
  id_usuario        Int
  /// Caminho relativo no storage: "diario/uuid-timestamp.jpg"
  foto_url          String?
  descricao         String
  data_registro     DateTime   @default(now()) @db.Timestamp(6)
  /// Campos de Auditoria Geográfica (Fase 3)
  latitude          Decimal?   @db.Decimal(10, 7)
  longitude         Decimal?   @db.Decimal(10, 7)
  status_auditoria  String     @default("AUTOMATICO")
  justificativa_gps String?
  tb_obra           tb_obra    @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade, onUpdate: NoAction)
  tb_usuario        tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_obra], map: "idx_diario_obra")
  @@index([id_usuario], map: "idx_diario_usuario")
}

/// Tarefas atribuídas a membros de uma obra
model tb_tarefa {
  id_tarefa            Int                 @id @default(autoincrement())
  id_obra              Int
  titulo               String
  descricao            String?
  /// PENDENTE | EM_ANDAMENTO | CONCLUIDA
  status               String              @default("PENDENTE")
  /// BAIXA | NORMAL | ALTA | URGENTE
  prioridade           String              @default("NORMAL")
  prazo                DateTime?           @db.Date
  criado_em            DateTime            @default(now()) @db.Timestamp(6)
  /// 0 a 100
  percentual_concluido Int                 @default(0)
  foto_comprovante     String?
  motivo_pausa         String?
  tb_obra              tb_obra             @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade, onUpdate: NoAction)
  tb_tarefa_usuario    tb_tarefa_usuario[]

  @@index([id_obra], map: "idx_tarefa_obra")
}

model tb_tarefa_usuario {
  id_tarefa  Int
  id_usuario Int
  tb_tarefa  tb_tarefa  @relation(fields: [id_tarefa], references: [id_tarefa], onDelete: Cascade)
  tb_usuario tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@id([id_tarefa, id_usuario])
}

model tb_movimentacao_estoque {
  id_movimentacao   Int                 @id @default(autoincrement())
  id_estoque        Int
  id_usuario        Int
  tipo              String
  quantidade        Decimal             @db.Decimal(10, 3)
  origem_fornecedor String?
  data_registro     DateTime            @default(now()) @db.Timestamp(6)
  id_financeiro     Int?
  tb_estoque        tb_estoque_obra     @relation(fields: [id_estoque], references: [id_estoque], onDelete: Cascade)
  tb_financeiro     tb_financeiro_obra? @relation(fields: [id_financeiro], references: [id_financeiro])
  tb_usuario        tb_usuario          @relation(fields: [id_usuario], references: [id_usuario])
}

model tb_financeiro_obra {
  id_financeiro      Int                       @id @default(autoincrement())
  id_obra            Int
  id_usuario         Int
  tipo               String
  valor              Decimal                   @db.Decimal(12, 2)
  descricao          String?
  data_vencimento    DateTime?                 @db.Date
  data_pagamento     DateTime?                 @db.Date
  numero_nota_fiscal String?
  url_comprovante    String?
  criado_em          DateTime                  @default(now()) @db.Timestamp(6)
  tb_obra            tb_obra                   @relation(fields: [id_obra], references: [id_obra], onDelete: Cascade)
  tb_usuario         tb_usuario                @relation(fields: [id_usuario], references: [id_usuario])
  tb_movimentacao    tb_movimentacao_estoque[]
}

model tb_log_auditoria {
  id_log     Int         @id @default(autoincrement())
  id_usuario Int?
  acao       String
  target_id  Int?
  detalhes   String?
  ip_address String?
  criado_em  DateTime    @default(now()) @db.Timestamp(6)
  tb_usuario tb_usuario? @relation(fields: [id_usuario], references: [id_usuario], onUpdate: NoAction, map: "fk_log_usuario")

  @@index([id_usuario], map: "idx_log_usuario")
}

model tb_certificacao {
  id_certificacao Int        @id @default(autoincrement())
  id_usuario      Int
  nome            String
  data_emissao    DateTime?  @db.Date
  data_validade   DateTime?  @db.Date
  arquivo_url     String?
  criado_em       DateTime   @default(now()) @db.Timestamp(6)
  tb_usuario      tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@index([id_usuario], map: "idx_certificacao_usuario")
  @@index([data_validade], map: "idx_certificacao_validade")
}

/// RH Avançado: Gestão de Salários (Multi-Tenant)
model tb_rh_salario {
  id_salario      Int        @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente      Int
  id_usuario      Int
  salario_base    Decimal    @db.Decimal(12, 2)
  bonus           Decimal    @default(0) @db.Decimal(12, 2)
  desconto        Decimal    @default(0) @db.Decimal(12, 2)
  vale_refeicao   Decimal    @default(0) @db.Decimal(10, 2)
  vale_transporte Decimal    @default(0) @db.Decimal(10, 2)
  data_inicio     DateTime   @db.Date
  data_fim        DateTime?  @db.Date
  observacoes     String?
  criado_em       DateTime   @default(now()) @db.Timestamp(6)
  atualizado_em   DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente      tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_rh_salario_cliente")
  tb_usuario      tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "fk_rh_salario_usuario")

  @@index([id_cliente], map: "idx_rh_salario_cliente")
  @@index([id_usuario], map: "idx_rh_salario_usuario")
  @@index([id_cliente, id_usuario], map: "idx_rh_salario_cliente_usuario")
}

/// RH Avançado: Dados Residenciais (Multi-Tenant)
model tb_rh_residencial {
  id_residencial   Int        @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente       Int
  id_usuario       Int
  logradouro       String
  numero           String
  complemento      String?
  bairro           String
  cidade           String
  estado           String     @db.Char(2)
  cep              String
  ponto_referencia String?
  telefone         String?
  email_pessoal    String?
  criado_em        DateTime   @default(now()) @db.Timestamp(6)
  atualizado_em    DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente       tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_rh_residencial_cliente")
  tb_usuario       tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "fk_rh_residencial_usuario")

  @@index([id_cliente], map: "idx_rh_residencial_cliente")
  @@index([id_usuario], map: "idx_rh_residencial_usuario")
  @@index([id_cliente, id_usuario], map: "idx_rh_residencial_cliente_usuario")
}

/// RH Avançado: Contas Bancárias para Pagamento (Multi-Tenant)
model tb_rh_conta_banco {
  id_conta_banco Int        @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente     Int
  id_usuario     Int
  /// ex: "Itaú", "Bradesco", "Caixa"
  banco          String
  /// "CORRENTE" | "POUPANÇA"
  tipo_conta     String
  agencia        String
  numero_conta   String
  digito_conta   String?
  chave_pix      String?
  titular_conta  String
  cpf_titular    String
  ativo          Boolean    @default(true)
  criado_em      DateTime   @default(now()) @db.Timestamp(6)
  atualizado_em  DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente     tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_rh_conta_banco_cliente")
  tb_usuario     tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "fk_rh_conta_banco_usuario")

  @@index([id_cliente], map: "idx_rh_conta_banco_cliente")
  @@index([id_usuario], map: "idx_rh_conta_banco_usuario")
  @@index([id_cliente, id_usuario], map: "idx_rh_conta_banco_cliente_usuario")
}

/// RH Avançado: Folha de Ponto / Diária (Multi-Tenant)
model tb_rh_ponto_diaria {
  id_ponto_diaria   Int        @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente        Int
  id_usuario        Int
  /// Obra onde a diária foi trabalhada
  id_obra           Int?
  data_ponto        DateTime   @db.Date
  hora_entrada      DateTime?  @db.Timestamp(6)
  hora_saida        DateTime?  @db.Timestamp(6)
  horas_trabalhadas Decimal    @default(0) @db.Decimal(5, 2)
  horas_extras      Decimal    @default(0) @db.Decimal(5, 2)
  valor_diaria      Decimal    @db.Decimal(10, 2)
  /// "PENDENTE" | "APROVADO" | "REJEITADO"
  status            String     @default("PENDENTE")
  observacoes       String?
  criado_em         DateTime   @default(now()) @db.Timestamp(6)
  atualizado_em     DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente        tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_rh_ponto_cliente")
  tb_obra           tb_obra?   @relation(fields: [id_obra], references: [id_obra], map: "fk_rh_ponto_obra")
  tb_usuario        tb_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "fk_rh_ponto_usuario")

  @@index([id_cliente], map: "idx_rh_ponto_cliente")
  @@index([id_usuario], map: "idx_rh_ponto_usuario")
  @@index([id_cliente, id_usuario], map: "idx_rh_ponto_cliente_usuario")
  @@index([id_obra], map: "idx_rh_ponto_obra")
  @@index([data_ponto], map: "idx_rh_ponto_data")
}

/// RH Recrutamento: Vagas de Emprego (Multi-Tenant)
model tb_vaga {
  id_vaga       Int             @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente    Int
  titulo        String
  descricao     String?
  requisitos    String?
  salario       Decimal?        @db.Decimal(12, 2)
  tipo_contrato String?
  status        String          @default("ABERTA")
  id_obra       Int?
  criado_em     DateTime        @default(now()) @db.Timestamp(6)
  atualizado_em DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  tb_candidato  tb_candidato[]
  tb_entrevista tb_entrevista[]
  tb_cliente    tb_cliente      @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_vaga_cliente")
  tb_obra       tb_obra?        @relation(fields: [id_obra], references: [id_obra], map: "fk_vaga_obra")

  @@index([id_cliente], map: "idx_vaga_cliente")
  @@index([id_obra], map: "idx_vaga_obra")
}

/// RH Recrutamento: Candidatos (Multi-Tenant)
model tb_candidato {
  id_candidato  Int             @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente    Int
  /// Vaga à qual o candidato está vinculado (opcional)
  id_vaga       Int?
  nome          String
  email         String?
  telefone      String?
  cpf           String?
  linkedin_url  String?
  /// URL do currículo armazenado (upload futuro)
  curriculo_url String?
  /// "INDICACAO" | "LINKEDIN" | "SITE" | "WALK_IN" | "OUTRO"
  fonte         String?
  status        String          @default("NOVO")
  observacoes   String?
  criado_em     DateTime        @default(now()) @db.Timestamp(6)
  atualizado_em DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente    tb_cliente      @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_candidato_cliente")
  tb_vaga       tb_vaga?        @relation(fields: [id_vaga], references: [id_vaga], map: "fk_candidato_vaga")
  tb_entrevista tb_entrevista[]

  @@index([id_cliente], map: "idx_candidato_cliente")
  @@index([id_vaga], map: "idx_candidato_vaga")
  @@index([id_cliente, status], map: "idx_candidato_cliente_status")
}

/// RH Recrutamento: Banco de Talentos (Multi-Tenant)
model tb_talento {
  id_talento         Int        @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente         Int
  nome               String
  email              String?
  telefone           String?
  cpf                String?
  linkedin_url       String?
  curriculo_url      String?
  cargo_desejado     String?
  /// "CLT" | "PJ" | "TEMPORARIO" | "DIARISTA"
  tipo_contrato      String?
  pretensao_salarial Decimal?   @db.Decimal(12, 2)
  /// "IMEDIATA" | "15_DIAS" | "30_DIAS" | "60_DIAS"
  disponibilidade    String?
  /// Texto livre com skills
  habilidades        String?
  observacoes        String?
  ativo              Boolean    @default(true)
  criado_em          DateTime   @default(now()) @db.Timestamp(6)
  atualizado_em      DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  tb_cliente         tb_cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_talento_cliente")

  @@index([id_cliente], map: "idx_talento_cliente")
  @@index([id_cliente, ativo], map: "idx_talento_cliente_ativo")
}

/// RH Recrutamento: Entrevistas (Multi-Tenant)
model tb_entrevista {
  id_entrevista   Int          @id @default(autoincrement())
  /// Isolamento Multi-Tenant (CRÍTICO)
  id_cliente      Int
  id_candidato    Int
  id_vaga         Int?
  /// Nome do entrevistador (texto livre por ora)
  entrevistador   String?
  tipo            String       @default("ONLINE")
  status          String       @default("AGENDADA")
  data_hora       DateTime     @db.Timestamp(6)
  duracao_minutos Int?         @default(60)
  /// Endereço físico ou link da reunião
  local_ou_link   String?
  /// Parecer do entrevistador após a entrevista
  feedback        String?
  /// Avaliação de 1 a 5
  nota            Int?
  criado_em       DateTime     @default(now()) @db.Timestamp(6)
  atualizado_em   DateTime     @default(now()) @updatedAt @db.Timestamp(6)
  tb_candidato    tb_candidato @relation(fields: [id_candidato], references: [id_candidato], onDelete: Cascade, map: "fk_entrevista_candidato")
  tb_cliente      tb_cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "fk_entrevista_cliente")
  tb_vaga         tb_vaga?     @relation(fields: [id_vaga], references: [id_vaga], map: "fk_entrevista_vaga")

  @@index([id_cliente], map: "idx_entrevista_cliente")
  @@index([id_candidato], map: "idx_entrevista_candidato")
  @@index([id_vaga], map: "idx_entrevista_vaga")
  @@index([id_cliente, data_hora], map: "idx_entrevista_cliente_data")
}
